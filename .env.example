# Copy to `.env` locally, or set the same values in your Vercel Project Environment Variables.
#
# Notes:
# - `AUTH_SECRET` and `DATA_ENCRYPTION_KEY` must be at least 32 characters.
# - `CRON_SECRET` is required in production because your Vercel cron endpoint checks `Authorization: Bearer <CRON_SECRET>`.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"

AUTH_SECRET="replace-me-auth-secret-32-plus-chars"
DATA_ENCRYPTION_KEY="replace-me-data-encryption-key-32-plus-chars"

# Use your real public URL in production.
BETTER_AUTH_URL="https://YOUR-DOMAIN"
NEXT_PUBLIC_APP_URL="https://YOUR-DOMAIN"

# Optional: only needed for Telegram webhook setup hints / local webhook tunneling.
# - Local testing: set this to your ngrok https origin (no trailing slash).
# - Production: set to `https://YOUR-DOMAIN`.
NEXT_PUBLIC_TELEGRAM_WEBHOOK_BASE_URL="https://YOUR-DOMAIN"

# Required for production if you want Telegram features enabled.
TELEGRAM_BOT_TOKEN=""

# Optional (delivery integration)
NOVA_POSHTA_API_KEY=""

# Google Sheets integration (preferred: base64-encoded service account JSON)
GOOGLE_SERVICE_ACCOUNT_JSON_B64=""
# Alternative:
# GOOGLE_SERVICE_ACCOUNT_JSON="...raw JSON string..."

# Required in production to protect the cron endpoint.
CRON_SECRET="replace-me-cron-secret-32-plus-chars"

# Defaults are also fine; these are just included for clarity.
RATE_LIMIT_WEBHOOK_PER_MINUTE="60"
RATE_LIMIT_CRON_PER_MINUTE="20"

# Optional error tracking (Sentry/etc.)
ERROR_TRACKING_DSN=""

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"
AUTH_SECRET="replace-with-very-long-random-string-32-plus-chars"
DATA_ENCRYPTION_KEY="replace-with-very-long-random-string-32-plus-chars"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# HTTPS tunnel for Telegram setWebhook while developing locally (ngrok). Example:
# NEXT_PUBLIC_TELEGRAM_WEBHOOK_BASE_URL="https://YOUR-SUBDOMAIN.ngrok-free.app"

# Stage 2+ integrations
TELEGRAM_BOT_TOKEN=""
NOVA_POSHTA_API_KEY=""
GOOGLE_SERVICE_ACCOUNT_JSON=""
CRON_SECRET=""
RATE_LIMIT_WEBHOOK_PER_MINUTE="60"
RATE_LIMIT_CRON_PER_MINUTE="20"
ERROR_TRACKING_DSN=""

