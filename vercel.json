{
  "installCommand": "bun install --frozen-lockfile",
  "buildCommand": "bun run build",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/process-sync-jobs",
      "schedule": "*/5 * * * *",
      "headers": {
        "Authorization": "Bearer ${CRON_SECRET}"
      }
    }
  ]
}

